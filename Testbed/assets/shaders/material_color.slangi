
#ifndef NWB_MATERIAL_COLOR_SLANGI
#define NWB_MATERIAL_COLOR_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include <common/math.slangi>


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Clamps a material's computed surface color to the displayable [0,1] range. A material that wants a color
// transform applies it directly in its surface hook (the engine has no compile-time color variant).
half3 nwbMaterialVertexColor(half3 color){
    return clamp(color, half3(0.0), half3(1.0));
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

