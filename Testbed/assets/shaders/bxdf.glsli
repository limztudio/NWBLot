////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_PROJECT_BXDF_GLSLI
#define NWB_PROJECT_BXDF_GLSLI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_PROJECT_BXDF
#define NWB_PROJECT_BXDF 0
#endif

#ifndef NWB_PROJECT_TINT
#define NWB_PROJECT_TINT 0
#endif

mediump vec3 nwbProjectApplyBxdf(mediump vec3 color){
#if NWB_PROJECT_BXDF == 0
    return color;
#elif NWB_PROJECT_BXDF == 1
    return sqrt(max(color, vec3(0.0)));
#else
    return color;
#endif
}

mediump vec3 nwbProjectApplyTint(mediump vec3 color){
#if NWB_PROJECT_TINT == 1
    return color * vec3(1.0, 0.92, 0.85);
#else
    return color;
#endif
}

mediump vec3 nwbProjectBxdfVertex(mediump vec3 color){
    return clamp(nwbProjectApplyTint(nwbProjectApplyBxdf(color)), vec3(0.0), vec3(1.0));
}

mediump vec3 nwbProjectBxdfPixel(mediump vec3 color){
    return color;
}

vec3 nwbProjectSafeNormalize(vec3 value, vec3 fallback){
    const float lengthSquared = dot(value, value);
    return lengthSquared > 0.000001 ? (value * inversesqrt(lengthSquared)) : fallback;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

