#cmakedefine HAVE_PTHREAD_SETNAME_NP_GNU 1

/* Define to 1 if you have the `epoll_create1' function. */
#cmakedefine HAVE_EPOLL_CREATE1 1

/* Define to 1 if you have the `lseek64' function. */
#cmakedefine HAVE_LSEEK64 1

