////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Transparent smoke surface hook fragment. Demonstrates a per-material color transform expressed as a hook (not
// a compile-time variant): the base color is square-root transformed and warm-tinted. The cook wraps it with the
// engine pixel-shader authoring + this material's typed .bind to generate the G-buffer pixel shader.
#include "smoke_material_color.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbMeshSurface nwbMaterialSurface(){
    const NwbMeshInstanceData instance = nwbMeshLoadInstance();
    const NwbSmokeSurfaceMaterial surface = nwbMaterialBindLoadSurface(instance);
    const NwbSmokeRuntimeMaterial runtime = nwbMaterialBindLoadRuntime(instance);
    const float4 tinted = surface.base_color * runtime.color_tint;
    const float3 baseColor = nwbSmokeMaterialVertexColor(tinted.rgb);
    const float3 transmittance = nwbSmokeMaterialTransmittance(tinted.rgb, tinted.a);
    return nwbMakeMeshSurface(baseColor, inNormal, 0.0, 0.0, transmittance);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
