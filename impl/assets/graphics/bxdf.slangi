////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_BXDF_SLANGI
#define NWB_BXDF_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include <nwb_shader_math.slangi>


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_BXDF_MODE
#error "NWB_BXDF_MODE must be defined by shader metadata"
#endif

#ifndef NWB_BXDF_TINT
#error "NWB_BXDF_TINT must be defined by shader metadata"
#endif

float3 nwbApplyBxdf(float3 color){
#if NWB_BXDF_MODE == 0
    return color;
#elif NWB_BXDF_MODE == 1
    return sqrt(max(color, float3(0.0)));
#else
    return color;
#endif
}

float3 nwbApplyBxdfTint(float3 color){
#if NWB_BXDF_TINT == 1
    return color * float3(1.0, 0.92, 0.85);
#else
    return color;
#endif
}

float3 nwbBxdfVertex(float3 color){
    return clamp(nwbApplyBxdfTint(nwbApplyBxdf(color)), float3(0.0), float3(1.0));
}

float3 nwbBxdfPixel(float3 color){
    return color;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

