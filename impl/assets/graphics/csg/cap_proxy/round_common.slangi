#ifndef NWB_GRAPHICS_CSG_SHAPE_CAP_PROXY_ROUND_COMMON_SLANGI
#define NWB_GRAPHICS_CSG_SHAPE_CAP_PROXY_ROUND_COMMON_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "../runtime.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#define NWB_CSG_CAP_PROXY_PI 3.14159265
#define NWB_CSG_CAP_PROXY_TWO_PI 6.28318531
#define NWB_CSG_CAP_PROXY_MAX_ROWS 7u


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float nwbCsgCapProxyInflatedRoundRadius(const float radiusShape, const float maxHalfAngle){
    const float radius = max(radiusShape, 0.0001);
    const float inflationScale = 1.0 / max(cos(maxHalfAngle), 0.25);
    return radius * inflationScale;
}

float nwbCsgCapProxyRoundRadiusSlack(const float radiusShape, const float maxHalfAngle){
    const float radius = max(radiusShape, 0.0001);
    return nwbCsgCapProxyInflatedRoundRadius(radius, maxHalfAngle) - radius;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
