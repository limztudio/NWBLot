[material_constant]
struct NwbSurfaceMaterial{
    [default("half4(1.0, 1.0, 1.0, 1.0)")]
    half4 base_color;
};

[material_mutable]
struct NwbRuntimeMaterial{
    [default("half4(1.0, 1.0, 1.0, 1.0)")]
    half4 color_tint;
};

NwbSurfaceMaterial surface;
NwbRuntimeMaterial runtime;


