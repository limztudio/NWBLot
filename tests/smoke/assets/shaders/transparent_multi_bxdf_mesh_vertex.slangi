////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_TRANSPARENT_MULTI_BXDF_MESH_VERTEX_SLANGI
#define NWB_TRANSPARENT_MULTI_BXDF_MESH_VERTEX_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbMeshGeneratedVertex nwbMeshBuildVertex(
    uint triangleIndex,
    uint corner,
    NwbMeshSourceVertex source,
    const NwbMeshInstanceData instance
){
    const NwbTransparentMultiBxdfSurfaceMaterial surface = nwbMaterialBindLoadSurface(instance);
    const NwbTransparentMultiBxdfRuntimeMaterial runtime = nwbMaterialBindLoadRuntime(instance);
    const float4 tintedColor = surface.base_color * runtime.color_tint;
    return nwbMeshBuildGeneratedVertex(
        source.clipPosition,
        nwbMeshTransformDirection(source.normal, instance),
        float4(nwbMeshTransformDirection(source.tangent.xyz, instance), source.tangent.w),
        source.uv0,
        float4(nwbTransparentMultiBxdfVertexColor(tintedColor.rgb), tintedColor.a),
        source.worldPosition
    );
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
