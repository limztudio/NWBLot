#ifndef NWB_GRAPHICS_GI_SURFEL_CONSTANTS_SLANGI
#define NWB_GRAPHICS_GI_SURFEL_CONSTANTS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Per-frame surfel GI parameters, shared by the spawn / hash-build / trace passes and the deferred-lighting gather.
// One dedicated CB (the scene-shading CB is 16 bytes and the push ceiling is 128 bytes). Packed as five float4 lanes;
// mirrored by the C++ NwbSurfelConstantsGpu. The C++ side writes the runtime values each frame (camera position for
// distance-scaled spawn/recycle, the frame index for the per-frame R2 ray rotation + age comparisons, and the update
// divisor which is 1 on the bootstrap frame so every surfel is seeded in one frame).
struct NwbSurfelConstants{
    float4 cameraPositionCellSize;  // xyz = camera world position, w = hash cell size (= 2 * max surfel radius)
    float4 hashPoolFrameDivisor;    // x = hash cell count (pow2), y = pool capacity, z = frame index, w = update divisor
    float4 coverageRadiusBiasHyst;  // x = spawn coverage threshold, y = default spawn radius, z = normal bias, w = hysteresis
    float4 ageRaysTileScreen;       // x = max age (frames before recycle), y = rays/surfel, z = spawn tile (px), w = screen width
    float4 screenHeightPad;         // x = screen height, yzw = pad
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
