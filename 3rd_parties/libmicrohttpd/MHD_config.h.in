/* MHD_config.h generated by CMake for the NWB vendored build. */

/* *** Basic OS/compiler information *** */

/* This is a Windows system */
#cmakedefine WINDOWS 1

/* This is a Linux system */
#cmakedefine LINUX 1

/* Define if MS VC compiler is used */
#cmakedefine MSVC 1

/* Define that this C compiler does not support VLAs */
#cmakedefine __STDC_NO_VLA__ 1

/* Define to 1 if C supports variable-length arrays. */
#cmakedefine HAVE_C_VARARRAYS 1

/* Define to 1 if your C compiler supports inline functions. */
#cmakedefine INLINE_FUNC 1

/* Define to prefix which will be used with MHD inline functions. */
#define _MHD_static_inline @NWB_MHD_STATIC_INLINE@

/* Define to 1 if you have __builtin_bswap32() builtin function */
#cmakedefine MHD_HAVE___BUILTIN_BSWAP32 1

/* Define to 1 if you have __builtin_bswap64() builtin function */
#cmakedefine MHD_HAVE___BUILTIN_BSWAP64 1

/* The size of `size_t', as computed by sizeof. */
#define SIZEOF_SIZE_T @SIZEOF_SIZE_T@

/* The size of `tv_sec' member of `struct timeval', as computed by sizeof */
#define SIZEOF_STRUCT_TIMEVAL_TV_SEC @SIZEOF_STRUCT_TIMEVAL_TV_SEC@

/* The size of `int64_t', as computed by sizeof. */
#define SIZEOF_INT64_T @SIZEOF_INT64_T@

/* The size of `uint64_t', as computed by sizeof. */
#define SIZEOF_UINT64_T @SIZEOF_UINT64_T@

/* The size of `int', as computed by sizeof. */
#define SIZEOF_INT @SIZEOF_INT@

/* The size of `unsigned int', as computed by sizeof. */
#define SIZEOF_UNSIGNED_INT @SIZEOF_UNSIGNED_INT@

/* The size of `unsigned long long', as computed by sizeof. */
#define SIZEOF_UNSIGNED_LONG_LONG @SIZEOF_UNSIGNED_LONG_LONG@

/* Define to supported 'noreturn' function declaration */
#define _MHD_NORETURN @NWB_MHD_NORETURN@

/* *** MHD configuration *** */
/* Undef to disable feature */

/* Enable basic Auth support */
#cmakedefine BAUTH_SUPPORT 1

/* Enable digest Auth support */
#cmakedefine DAUTH_SUPPORT 1

/* The default HTTP Digest Auth default maximum nc (nonce count) value */
#define MHD_DAUTH_DEF_MAX_NC_ @MHD_DAUTH_DEF_MAX_NC_@

/* The default HTTP Digest Auth default nonce timeout value (in seconds) */
#define MHD_DAUTH_DEF_TIMEOUT_ @MHD_DAUTH_DEF_TIMEOUT_@

/* Enable MD5 hashing support. */
#cmakedefine MHD_MD5_SUPPORT 1

/* Enable SHA-256 hashing support. */
#cmakedefine MHD_SHA256_SUPPORT 1

/* Enable SHA-512/256 hashing support. */
#cmakedefine MHD_SHA512_256_SUPPORT 1

/* Enable postprocessor.c */
#cmakedefine HAVE_POSTPROCESSOR 1

/* Enable error messages */
#cmakedefine HAVE_MESSAGES 1

/* Enable HTTP Upgrade support. */
#cmakedefine UPGRADE_SUPPORT 1

/* Enable HTTP cookie parsing support. */
#cmakedefine COOKIE_SUPPORT 1

/* *** OS features *** */

/* Provides IPv6 headers */
#cmakedefine HAVE_INET6 1

/* Define to 1 if your system allow overriding the value of FD_SETSIZE macro */
#cmakedefine HAS_FD_SETSIZE_OVERRIDABLE 1

/* Define to use socketpair for inter-thread communication */
#cmakedefine _MHD_ITC_SOCKETPAIR 1

/* Define to use eventfd for inter-thread communication (GNU/Linux) */
#cmakedefine _MHD_ITC_EVENTFD 1

/* Define to use pipe for inter-thread communication (POSIX) */
#cmakedefine _MHD_ITC_PIPE 1

/* define to use W32 threads */
#cmakedefine MHD_USE_W32_THREADS 1

/* define to use POSIX threads */
#cmakedefine MHD_USE_POSIX_THREADS 1

#ifdef WINDOWS
#ifndef _WIN32_WINNT
/* MHD supports Windows Vista and later W32 systems */
#define _WIN32_WINNT @NWB_MHD_WIN32_WINNT@
#endif /* _WIN32_WINNT */
#endif /* WINDOWS */

/* winsock poll is available only on Vista and later; CMake probes poll() directly on
   POSIX, so HAVE_POLL is emitted unconditionally below regardless of platform. */
#cmakedefine HAVE_POLL 1

/* Define to 1 if you have the <winsock2.h> header file. */
#cmakedefine HAVE_WINSOCK2_H 1

/* Define to 1 if you have the <ws2tcpip.h> header file. */
#cmakedefine HAVE_WS2TCPIP_H 1

/* Define to 1 if you have the `_lseeki64' function. */
#cmakedefine HAVE___LSEEKI64 1

/* Define to 1 if you have the `gmtime_s' function in W32 form. */
#cmakedefine HAVE_W32_GMTIME_S 1

/* Define to 1 if you have the usable `calloc' function. */
#cmakedefine HAVE_CALLOC 1

/* Define if you have usable assert() and assert.h */
#cmakedefine HAVE_ASSERT 1

/* Define to 1 if you have the <limits.h> header file. */
#cmakedefine HAVE_LIMITS_H 1

/* Define to 1 if you have the <stddef.h> header file. */
#cmakedefine HAVE_STDDEF_H 1

/* Define to 1 if you have the <stdlib.h> header file. */
#cmakedefine HAVE_STDLIB_H 1

/* Define to 1 if you have the <string.h> header file. */
#cmakedefine HAVE_STRING_H 1

/* Define to 1 if you have the <sys/stat.h> header file. */
#cmakedefine HAVE_SYS_STAT_H 1

/* Define to 1 if you have the <time.h> header file. */
#cmakedefine HAVE_TIME_H 1

/* Define to 1 if you have the `snprintf' function. */
#cmakedefine HAVE_SNPRINTF 1

/* Define to 1 if you have the <inttypes.h> header file. */
#cmakedefine HAVE_INTTYPES_H 1

/* Define to 1 if you have the <stdbool.h> header file and <stdbool.h> defines
   'bool' type. */
#cmakedefine HAVE_STDBOOL_H 1

/* Define to 1 if you have the real boolean type. */
#cmakedefine HAVE_REAL_BOOL 1

/* Define to 1 if you have the real boolean type. */
#cmakedefine HAVE_BUILTIN_TYPE_BOOL 1

#ifndef HAVE_STDBOOL_H
/* Define to type name which will be used as boolean type. */
#define bool int

/* Define to value interpreted by compiler as boolean "false", if "false" is
   not defined by system headers. */
#define false 0

/* Define to value interpreted by compiler as boolean "true", if "true" is
   not defined by system headers. */
#define true (!0)
#endif /* !HAVE_STDBOOL_H */

/* Define to 1 if you have the `getsockname' function. */
#cmakedefine HAVE_GETSOCKNAME 1

/* Define if you have usable `getsockname' function. */
#cmakedefine MHD_USE_GETSOCKNAME 1

/* Define to 1 if your compiler supports __func__ magic-macro. */
#cmakedefine HAVE___FUNC__ 1

/* Define to 1 if your compiler supports 'alignof()' */
#cmakedefine HAVE_C_ALIGNOF 1

/* Define to 1 if you have the <stdalign.h> header file. */
#cmakedefine HAVE_STDALIGN_H 1

/* Define to 1 if you have the 'rand' function. */
#cmakedefine HAVE_RAND 1

/* *** Headers information *** */

/* Define to 1 if you have the <errno.h> header file. */
#cmakedefine HAVE_ERRNO_H 1

/* Define to 1 if you have the <fcntl.h> header file. */
#cmakedefine HAVE_FCNTL_H 1

/* Define to 1 if you have the <locale.h> header file. */
#cmakedefine HAVE_LOCALE_H 1

/* Define to 1 if you have the <math.h> header file. */
#cmakedefine HAVE_MATH_H 1

/* Define to 1 if you have the <sdkddkver.h> header file. */
#cmakedefine HAVE_SDKDDKVER_H 1

/* Define to 1 if you have the <memory.h> header file. */
#cmakedefine HAVE_MEMORY_H 1

/* Define to 1 if you have the <stdint.h> header file. */
#cmakedefine HAVE_STDINT_H 1

/* Define to 1 if you have the <stdio.h> header file. */
#cmakedefine HAVE_STDIO_H 1

/* Define to 1 if you have the <strings.h> header file. */
#cmakedefine HAVE_STRINGS_H 1

/* Define to 1 if you have the <sys/types.h> header file. */
#cmakedefine HAVE_SYS_TYPES_H 1

/* Define to 1 if you have the <windows.h> header file. */
#cmakedefine HAVE_WINDOWS_H 1

/* *** POSIX headers (Linux/Unix vendored build) *** */

/* Define to 1 if you have the <unistd.h> header file. */
#cmakedefine HAVE_UNISTD_H 1

/* Define to 1 if you have the <arpa/inet.h> header file. */
#cmakedefine HAVE_ARPA_INET_H 1

/* Define to 1 if you have the <netinet/in.h> header file. */
#cmakedefine HAVE_NETINET_IN_H 1

/* Define to 1 if you have the <netinet/tcp.h> header file. */
#cmakedefine HAVE_NETINET_TCP_H 1

/* Define to 1 if you have the <netinet/in_systm.h> header file. */
#cmakedefine HAVE_NETINET_IN_SYSTM_H 1

/* Define to 1 if you have the <net/if.h> header file. */
#cmakedefine HAVE_NET_IF_H 1

/* Define to 1 if you have the <netdb.h> header file. */
#cmakedefine HAVE_NETDB_H 1

/* Define to 1 if you have the <sys/socket.h> header file. */
#cmakedefine HAVE_SYS_SOCKET_H 1

/* Define to 1 if you have the <sys/time.h> header file. */
#cmakedefine HAVE_SYS_TIME_H 1

/* Define to 1 if you have the <sys/select.h> header file. */
#cmakedefine HAVE_SYS_SELECT_H 1

/* Define to 1 if you have the <sys/mman.h> header file. */
#cmakedefine HAVE_SYS_MMAN_H 1

/* Define to 1 if you have the <sys/ioctl.h> header file. */
#cmakedefine HAVE_SYS_IOCTL_H 1

/* Define to 1 if you have the <sys/param.h> header file. */
#cmakedefine HAVE_SYS_PARAM_H 1

/* Define to 1 if you have the <sys/msg.h> header file. */
#cmakedefine HAVE_SYS_MSG_H 1

/* Define to 1 if you have the <sys/uio.h> header file. */
#cmakedefine HAVE_SYS_UIO_H 1

/* Define to 1 if you have the <sys/eventfd.h> header file. */
#cmakedefine HAVE_SYS_EVENTFD_H 1

/* Define to 1 if you have the <signal.h> header file. */
#cmakedefine HAVE_SIGNAL_H 1

/* Define to 1 if you have the <pthread.h> header file. */
#cmakedefine HAVE_PTHREAD_H 1

/* Define to 1 if you have the <poll.h> header file. */
#cmakedefine HAVE_POLL_H 1

