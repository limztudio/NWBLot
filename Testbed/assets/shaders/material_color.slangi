////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_MATERIAL_COLOR_SLANGI
#define NWB_MATERIAL_COLOR_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include <common/math.slangi>


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_MATERIAL_COLOR_TRANSFORM
#error "NWB_MATERIAL_COLOR_TRANSFORM must be defined by shader metadata"
#endif

#ifndef NWB_MATERIAL_VERTEX_TINT
#error "NWB_MATERIAL_VERTEX_TINT must be defined by shader metadata"
#endif

float3 nwbMaterialApplyColorTransform(float3 color){
#if NWB_MATERIAL_COLOR_TRANSFORM == 0
    return color;
#elif NWB_MATERIAL_COLOR_TRANSFORM == 1
    return sqrt(max(color, float3(0.0)));
#else
    return color;
#endif
}

float3 nwbMaterialApplyVertexTint(float3 color){
#if NWB_MATERIAL_VERTEX_TINT == 1
    return color * float3(1.0, 0.92, 0.85);
#else
    return color;
#endif
}

float3 nwbMaterialVertexColor(float3 color){
    return clamp(nwbMaterialApplyVertexTint(nwbMaterialApplyColorTransform(color)), float3(0.0), float3(1.0));
}

float3 nwbMaterialPixelColor(float3 color){
    return color;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

