////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_ASSETS_CSG_PLANE_EVAL_SLANGI
#define NWB_ASSETS_CSG_PLANE_EVAL_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float nwbCsgPlaneDistance(const float3 shapePosition, const NwbCsgCutter cutter){
    return dot(shapePosition, cutter.parameter0.xyz) + cutter.parameter0.w;
}

float3 nwbCsgPlaneNormal(const NwbCsgCutter cutter){
    return nwbCsgNormalizeOr(cutter.parameter0.xyz, float3(0.0, 1.0, 0.0));
}

NwbCsgSample nwbEvalCsgPlaneShape(const float3 shapePosition, const NwbCsgCutter cutter){
    NwbCsgSample sample;
    sample.distance = nwbCsgPlaneDistance(shapePosition, cutter);
    sample.normal = nwbCsgPlaneNormal(cutter);
    return sample;
}

#if defined(NWB_CSG_ENABLE_SHAPE_EVAL_CHAIN)
#if defined(NWB_CSG_SHAPE_EVAL_CHAIN)
#define NWB_CSG_PREVIOUS_SHAPE_EVAL_CHAIN NWB_CSG_SHAPE_EVAL_CHAIN
#else
#define NWB_CSG_PREVIOUS_SHAPE_EVAL_CHAIN nwbTryEvalProjectCsgShape
#endif

bool nwbTryEvalCsgPlaneShape(
    const uint shapeType,
    const float3 shapePosition,
    const NwbCsgCutter cutter,
    out NwbCsgSample outSample
){
    if(shapeType == NWB_CSG_EVAL_SHAPE_ID){
        outSample = nwbEvalCsgPlaneShape(shapePosition, cutter);
        return true;
    }
    return NWB_CSG_PREVIOUS_SHAPE_EVAL_CHAIN(shapeType, shapePosition, cutter, outSample);
}

#undef NWB_CSG_SHAPE_EVAL_CHAIN
#define NWB_CSG_SHAPE_EVAL_CHAIN nwbTryEvalCsgPlaneShape
#undef NWB_CSG_PREVIOUS_SHAPE_EVAL_CHAIN
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
