////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_BXDF_SLANGI
#define NWB_BXDF_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include <common/math.slangi>


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_BXDF_COLOR_TRANSFORM
#error "NWB_BXDF_COLOR_TRANSFORM must be defined by shader metadata"
#endif

#ifndef NWB_BXDF_VERTEX_TINT
#error "NWB_BXDF_VERTEX_TINT must be defined by shader metadata"
#endif

float3 nwbBxdfApplyColorTransform(float3 color){
#if NWB_BXDF_COLOR_TRANSFORM == 0
    return color;
#elif NWB_BXDF_COLOR_TRANSFORM == 1
    return sqrt(max(color, float3(0.0)));
#else
    return color;
#endif
}

float3 nwbBxdfApplyVertexTint(float3 color){
#if NWB_BXDF_VERTEX_TINT == 1
    return color * float3(1.0, 0.92, 0.85);
#else
    return color;
#endif
}

float3 nwbBxdfVertexColor(float3 color){
    return clamp(nwbBxdfApplyVertexTint(nwbBxdfApplyColorTransform(color)), float3(0.0), float3(1.0));
}

float3 nwbBxdfPixelColor(float3 color){
    return color;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

