
#ifndef NWB_GRAPHICS_MESH_SHADER_ENCODING_SLANGI
#define NWB_GRAPHICS_MESH_SHADER_ENCODING_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "meshlet_payload.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbMeshletBounds nwbMeshLoadMeshletBounds(const uint meshletIndex){
    const uint byteOffset = nwbMeshletBoundsByteOffset(meshletIndex);

    NwbMeshletBounds bounds;
    bounds.sphere = asfloat(g_NwbMeshletBounds.Load4(byteOffset + NWB_MESHLET_BOUNDS_SPHERE_BYTE_OFFSET));
    bounds.conePacked = g_NwbMeshletBounds.Load(byteOffset + NWB_MESHLET_BOUNDS_CONE_BYTE_OFFSET);
    return bounds;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

