////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_CSG_INTERVAL_SAMPLE_SLANGI
#define NWB_GRAPHICS_CSG_INTERVAL_SAMPLE_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "binding_slots.h"
#include "constants.h"

#include "../mesh/view_buffer.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_CSG_RECEIVER_EVENTS_WRITABLE
#define NWB_CSG_RECEIVER_EVENTS_WRITABLE 0
#endif

#ifndef NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
#define NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED 0
#endif

struct NwbCsgIntervalSampleState{
    uint4 workRect;
};

[[vk::binding(NWB_CSG_INTERVAL_BINDING_SAMPLE_STATE, NWB_CSG_INTERVAL_SAMPLE_SET)]]
ConstantBuffer<NwbCsgIntervalSampleState> g_NwbCsgIntervalSampleState;

#if NWB_CSG_RECEIVER_EVENTS_WRITABLE
// Event data layout: .x = receiverIndex, .y = faceSign, .z = asuint(linear depth), .w = unused.
[[vk::binding(NWB_CSG_INTERVAL_BINDING_RECEIVER_EVENT_DATA, NWB_CSG_INTERVAL_SAMPLE_SET), vk::image_format(NWB_CSG_RECEIVER_EVENT_DATA_IMAGE_FORMAT)]]
RWTexture2DArray<uint4> g_NwbCsgReceiverEventData;
[[vk::binding(NWB_CSG_INTERVAL_BINDING_RECEIVER_EVENT_COUNT, NWB_CSG_INTERVAL_SAMPLE_SET), vk::image_format(NWB_CSG_RECEIVER_EVENT_COUNT_IMAGE_FORMAT)]]
RWTexture2DArray<uint> g_NwbCsgReceiverEventCount;
#endif

#if NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
[[vk::binding(NWB_CSG_INTERVAL_BINDING_REMOVED_INTERVAL_DEPTH, NWB_CSG_INTERVAL_SAMPLE_SET)]]
Texture2DArray<float4> g_NwbCsgRemovedIntervalDepth;
[[vk::binding(NWB_CSG_INTERVAL_BINDING_REMOVED_INTERVAL_CAP_NORMAL, NWB_CSG_INTERVAL_SAMPLE_SET)]]
Texture2DArray<float4> g_NwbCsgRemovedIntervalCapNormal;
[[vk::binding(NWB_CSG_INTERVAL_BINDING_REMOVED_INTERVAL_DATA, NWB_CSG_INTERVAL_SAMPLE_SET)]]
Texture2DArray<uint4> g_NwbCsgRemovedIntervalData;
// Count layout: .x = removed-interval count, .y = flags.
[[vk::binding(NWB_CSG_INTERVAL_BINDING_REMOVED_INTERVAL_COUNT, NWB_CSG_INTERVAL_SAMPLE_SET)]]
Texture2DArray<uint2> g_NwbCsgRemovedIntervalCount;
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbCsgIntervalCapPixel{
    bool visible;
    float depth;
    float3 normal;
    float3 worldPosition;
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if NWB_CSG_RECEIVER_EVENTS_WRITABLE
uint nwbCsgReceiverEventLayerCount(){
    uint width = 1u;
    uint height = 1u;
    uint layerCount = 1u;
    g_NwbCsgReceiverEventData.GetDimensions(width, height, layerCount);
    return min(layerCount, NWB_CSG_RECEIVER_EVENT_LAYER_COUNT);
}
#endif

#if NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
uint nwbCsgRemovedIntervalLayerCount(){
    uint width = 1u;
    uint height = 1u;
    uint layerCount = 1u;
    g_NwbCsgRemovedIntervalDepth.GetDimensions(width, height, layerCount);
    return min(layerCount, NWB_CSG_REMOVED_INTERVAL_LAYER_COUNT);
}
#endif

#if NWB_CSG_RECEIVER_EVENTS_WRITABLE
void nwbCsgMarkReceiverSurfaceEvent(
    const float4 rasterPosition,
    const float3 worldPosition,
    const uint receiverIndex,
    const bool frontFace
){
    const uint layerCount = nwbCsgReceiverEventLayerCount();
    if(layerCount == 0u)
        return;

    const uint2 pixel = uint2(rasterPosition.xy);
    const uint4 workRect = g_NwbCsgIntervalSampleState.workRect;
    if(pixel.x < workRect.x || pixel.y < workRect.y || pixel.x >= workRect.z || pixel.y >= workRect.w)
        return;

    uint eventIndex;
    InterlockedAdd(g_NwbCsgReceiverEventCount[uint3(pixel, 0u)], 1u, eventIndex);
    // Overflow is derived downstream from (count > layerCount); the running count keeps
    // incrementing past the storable layer budget, so no separate overflow flag is needed.
    if(eventIndex >= layerCount)
        return;

    const uint faceSign = frontFace ? NWB_CSG_RECEIVER_EVENT_FACE_FRONT : NWB_CSG_RECEIVER_EVENT_FACE_BACK;
    const float eventLinearDepth = length(worldPosition - g_NwbMeshCameraPosition.xyz);
    const uint3 eventTexel = uint3(pixel, eventIndex);
    g_NwbCsgReceiverEventData[eventTexel] = uint4(receiverIndex, faceSign, asuint(eventLinearDepth), 0u);
}
#endif

float nwbCsgIntervalSampleSafeHomogeneousW(const float w){
    if(abs(w) >= 0.000001)
        return w;
    return w < 0.0 ? -0.000001 : 0.000001;
}

float3 nwbCsgIntervalSampleClipToWorldPosition(const float4 clipPosition){
    const float4 worldPosition = mul(g_NwbMeshClipToWorld, clipPosition);
    return worldPosition.xyz / nwbCsgIntervalSampleSafeHomogeneousW(worldPosition.w);
}

uint2 nwbCsgIntervalSampleFrameExtent(){
    uint width = 1u;
    uint height = 1u;
    uint layerCount = 1u;
#if NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
    g_NwbCsgRemovedIntervalDepth.GetDimensions(width, height, layerCount);
#elif NWB_CSG_RECEIVER_EVENTS_WRITABLE
    g_NwbCsgReceiverEventData.GetDimensions(width, height, layerCount);
#endif
    return uint2(width, height);
}

float2 nwbCsgIntervalSampleFrameSize(){
    const uint2 frameExtent = nwbCsgIntervalSampleFrameExtent();
    return float2(frameExtent);
}

float3 nwbCsgIntervalSamplePixelDepthToWorldPosition(const uint2 pixel, const float depth){
    const float2 frameSize = nwbCsgIntervalSampleFrameSize();
    const float2 uv = (float2(pixel) + 0.5) / max(frameSize, float2(1.0, 1.0));
    const float2 ndc = float2(uv.x * 2.0 - 1.0, 1.0 - uv.y * 2.0);
    return nwbCsgIntervalSampleClipToWorldPosition(float4(ndc, depth, 1.0));
}

float3 nwbCsgIntervalSampleNormalizeOr(const float3 value, const float3 fallback){
    const float lengthSquared = dot(value, value);
    if(lengthSquared <= 0.000001 || !isfinite(lengthSquared))
        return fallback;
    return value * rsqrt(lengthSquared);
}

float3 nwbCsgIntervalSampleVisibleCapNormal(const float3 normal, const float3 worldPosition){
    const float3 normalVector = nwbCsgIntervalSampleNormalizeOr(normal, float3(0.0, 0.0, 1.0));
    const float3 viewVector = nwbCsgIntervalSampleNormalizeOr(g_NwbMeshCameraPosition.xyz - worldPosition, normalVector);
    return dot(normalVector, viewVector) < 0.0 ? -normalVector : normalVector;
}

bool nwbCsgIntervalSamplePixelInFrame(const int2 pixel){
    const uint2 frameExtent = nwbCsgIntervalSampleFrameExtent();
    return pixel.x >= 0
        && pixel.y >= 0
        && uint(pixel.x) < frameExtent.x
        && uint(pixel.y) < frameExtent.y
    ;
}

bool nwbCsgIntervalSamplePixelInWorkRect(const int2 pixel){
    if(!nwbCsgIntervalSamplePixelInFrame(pixel))
        return false;

    const uint4 workRect = g_NwbCsgIntervalSampleState.workRect;
    return uint(pixel.x) >= workRect.x
        && uint(pixel.y) >= workRect.y
        && uint(pixel.x) < workRect.z
        && uint(pixel.y) < workRect.w
    ;
}

void nwbCsgSelectNearestIntervalCap(inout NwbCsgIntervalCapPixel result, const NwbCsgIntervalCapPixel candidate){
    if(!candidate.visible || candidate.depth >= result.depth)
        return;

    result = candidate;
}

#if NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
NwbCsgIntervalCapPixel nwbCsgSampleNearestRemovedIntervalCapAtPixel(const uint2 outputPixel, const uint2 intervalPixel){
    NwbCsgIntervalCapPixel result;
    result.visible = false;
    result.depth = 1e30;
    result.normal = float3(0.0, 0.0, 1.0);
    result.worldPosition = float3(0.0, 0.0, 0.0);
    if(!nwbCsgIntervalSamplePixelInWorkRect(int2(intervalPixel)))
        return result;

    const uint removedIntervalLayerCount = nwbCsgRemovedIntervalLayerCount();
    const uint rawIntervalCount = g_NwbCsgRemovedIntervalCount.Load(int4(int2(intervalPixel), 0, 0)).x;
    const uint intervalCount = min(rawIntervalCount, removedIntervalLayerCount);
    [unroll]
    for(uint layerIndex = 0u; layerIndex < NWB_CSG_REMOVED_INTERVAL_LAYER_COUNT; ++layerIndex){
        if(layerIndex >= intervalCount)
            break;

        const int4 texel = int4(int2(intervalPixel), int(layerIndex), 0);
        const uint4 intervalData = g_NwbCsgRemovedIntervalData.Load(texel);
        if((intervalData.y & NWB_CSG_REMOVED_INTERVAL_BACK_CAP_VISIBLE_FLAG) == 0u)
            continue;

        const float4 intervalDepth = g_NwbCsgRemovedIntervalDepth.Load(texel);
        const float capDepth = intervalDepth.y;
        if(!isfinite(capDepth) || capDepth >= result.depth)
            continue;

        const float3 capWorldPosition = nwbCsgIntervalSamplePixelDepthToWorldPosition(outputPixel, capDepth);
        result.visible = true;
        result.depth = capDepth;
        result.normal = nwbCsgIntervalSampleVisibleCapNormal(g_NwbCsgRemovedIntervalCapNormal.Load(texel).xyz, capWorldPosition);
        result.worldPosition = capWorldPosition;
    }

    return result;
}
#endif

#if defined(NWB_GRAPHICS_CSG_RUNTIME_SLANGI) && NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
bool nwbCsgReceiverRemovedIntervalPixelDiscardAtPixel(
    const uint2 intervalPixel,
    const uint receiverIndex,
    const float receiverLinearDepth,
    const float linearDepthTolerance
){
    if(!nwbCsgIntervalSamplePixelInWorkRect(int2(intervalPixel)))
        return false;

    const uint removedIntervalLayerCount = nwbCsgRemovedIntervalLayerCount();
    const uint rawIntervalCount = g_NwbCsgRemovedIntervalCount.Load(int4(int2(intervalPixel), 0, 0)).x;
    const uint intervalCount = min(rawIntervalCount, removedIntervalLayerCount);
    [unroll]
    for(uint layerIndex = 0u; layerIndex < NWB_CSG_REMOVED_INTERVAL_LAYER_COUNT; ++layerIndex){
        if(layerIndex >= intervalCount)
            break;

        const int4 texel = int4(int2(intervalPixel), int(layerIndex), 0);
        const uint4 intervalData = g_NwbCsgRemovedIntervalData.Load(texel);
        if(intervalData.x != receiverIndex)
            continue;

        const float4 intervalDepth = g_NwbCsgRemovedIntervalDepth.Load(texel);
        if(receiverLinearDepth + linearDepthTolerance < intervalDepth.z)
            continue;
        if(receiverLinearDepth > intervalDepth.w + linearDepthTolerance)
            continue;

        return true;
    }

    return false;
}

bool nwbCsgReceiverIntervalPixelDiscard(
    const float4 rasterPosition,
    const uint receiverIndex,
    const float3 worldPosition,
    const float worldDistanceTolerance
){
    if(!nwbCsgReceiverPixelDiscardWithWorldTolerance(
        receiverIndex,
        worldPosition,
        worldDistanceTolerance * NWB_CSG_RECEIVER_INTERVAL_WORLD_TOLERANCE_SCALE
    ))
        return false;

    const int2 pixelInt = int2(rasterPosition.xy);
    if(!nwbCsgIntervalSamplePixelInWorkRect(pixelInt))
        return false;

    const uint2 pixel = uint2(pixelInt);
    const float receiverLinearDepth = length(worldPosition - g_NwbMeshCameraPosition.xyz);
    // Use only the stable world-scaled tolerance. A screen-space fwidth() term explodes at the cut rim
    // and at grazing angles, pulsing the accept band frame-to-frame as the skinned mesh animates, which
    // was the dominant boundary shimmer in both the opaque and transparent paths.
    const float linearDepthTolerance = abs(worldDistanceTolerance) * NWB_CSG_RECEIVER_INTERVAL_LINEAR_DEPTH_TOLERANCE_SCALE;
    if(nwbCsgReceiverRemovedIntervalPixelDiscardAtPixel(pixel, receiverIndex, receiverLinearDepth, linearDepthTolerance))
        return true;

    [unroll]
    for(
        int offsetY = -NWB_CSG_RECEIVER_INTERVAL_DISCARD_NEIGHBOR_RADIUS;
        offsetY <= NWB_CSG_RECEIVER_INTERVAL_DISCARD_NEIGHBOR_RADIUS;
        ++offsetY
    ){
        [unroll]
        for(
            int offsetX = -NWB_CSG_RECEIVER_INTERVAL_DISCARD_NEIGHBOR_RADIUS;
            offsetX <= NWB_CSG_RECEIVER_INTERVAL_DISCARD_NEIGHBOR_RADIUS;
            ++offsetX
        ){
            if(offsetX == 0 && offsetY == 0)
                continue;

            const int2 intervalPixel = int2(pixel) + int2(offsetX, offsetY);
            if(!nwbCsgIntervalSamplePixelInWorkRect(intervalPixel))
                continue;

            if(nwbCsgReceiverRemovedIntervalPixelDiscardAtPixel(
                uint2(intervalPixel),
                receiverIndex,
                receiverLinearDepth,
                linearDepthTolerance
            ))
                return true;
        }
    }

    return false;
}
#endif

#if NWB_CSG_REMOVED_INTERVAL_SAMPLE_ENABLED
void nwbCsgSampleNearestRemovedIntervalCapNeighborhood(
    inout NwbCsgIntervalCapPixel result,
    const uint2 outputPixel
){
    [unroll]
    for(
        int offsetY = -NWB_CSG_REMOVED_INTERVAL_CAP_NEIGHBOR_RADIUS;
        offsetY <= NWB_CSG_REMOVED_INTERVAL_CAP_NEIGHBOR_RADIUS;
        ++offsetY
    ){
        [unroll]
        for(
            int offsetX = -NWB_CSG_REMOVED_INTERVAL_CAP_NEIGHBOR_RADIUS;
            offsetX <= NWB_CSG_REMOVED_INTERVAL_CAP_NEIGHBOR_RADIUS;
            ++offsetX
        ){
            if(offsetX == 0 && offsetY == 0)
                continue;

            const int2 neighborPixel = int2(outputPixel) + int2(offsetX, offsetY);
            if(!nwbCsgIntervalSamplePixelInWorkRect(neighborPixel))
                continue;

            nwbCsgSelectNearestIntervalCap(
                result,
                nwbCsgSampleNearestRemovedIntervalCapAtPixel(outputPixel, uint2(neighborPixel))
            );
        }
    }
}

NwbCsgIntervalCapPixel nwbCsgSampleNearestIntervalCap(const float4 rasterPosition){
    const uint2 pixel = uint2(rasterPosition.xy);
    NwbCsgIntervalCapPixel result = nwbCsgSampleNearestRemovedIntervalCapAtPixel(pixel, pixel);
    if(result.visible)
        return result;

    nwbCsgSampleNearestRemovedIntervalCapNeighborhood(result, pixel);
    return result;
}
#endif

#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

