////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_CSG_CAPSULE_CAP_PROXY_PROJECTION
#define NWB_CSG_CAPSULE_CAP_PROXY_PROJECTION


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float3 nwbCsgCapsuleProjectionAxisPoint(const float3 shapePosition, const NwbCsgCutter cutter){
    const float halfHeight = max(cutter.parameter0.y, 0.0);
    return float3(0.0, clamp(shapePosition.y, -halfHeight, halfHeight), 0.0);
}

float3 nwbCsgCapProxyEnlargeCapsuleShapePosition(
    const float3 shapePosition,
    const NwbCsgCutter cutter,
    const float radiusSlack
){
    if(radiusSlack <= 0.0)
        return shapePosition;

    const float radius = max(cutter.parameter0.x + radiusSlack, 0.0001);
    const float3 axisPoint = nwbCsgCapsuleProjectionAxisPoint(shapePosition, cutter);
    const float3 normal = nwbCsgNormalizeOr(shapePosition - axisPoint, nwbCsgCapsuleNormal(shapePosition, cutter));
    return axisPoint + normal * radius;
}

float3 nwbCsgCapProxyShrinkCapsuleShapePosition(
    const float3 shapePosition,
    const NwbCsgCutter cutter
){
    const float radius = max(cutter.parameter0.x, 0.0);
    const float3 axisPoint = nwbCsgCapsuleProjectionAxisPoint(shapePosition, cutter);
    const float3 normal = nwbCsgNormalizeOr(shapePosition - axisPoint, nwbCsgCapsuleNormal(shapePosition, cutter));
    return axisPoint + normal * radius;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
