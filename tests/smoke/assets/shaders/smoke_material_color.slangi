////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_SMOKE_MATERIAL_COLOR_SLANGI
#define NWB_SMOKE_MATERIAL_COLOR_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include <common/math.slangi>


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_SMOKE_MATERIAL_COLOR_TRANSFORM
#error "NWB_SMOKE_MATERIAL_COLOR_TRANSFORM must be defined by shader metadata"
#endif

#ifndef NWB_SMOKE_MATERIAL_VERTEX_TINT
#error "NWB_SMOKE_MATERIAL_VERTEX_TINT must be defined by shader metadata"
#endif

float3 nwbSmokeMaterialApplyColorTransform(float3 color){
#if NWB_SMOKE_MATERIAL_COLOR_TRANSFORM == 0
    return color;
#elif NWB_SMOKE_MATERIAL_COLOR_TRANSFORM == 1
    return sqrt(max(color, float3(0.0)));
#else
#error "unsupported NWB_SMOKE_MATERIAL_COLOR_TRANSFORM value"
#endif
}

float3 nwbSmokeMaterialApplyVertexTint(float3 color){
#if NWB_SMOKE_MATERIAL_VERTEX_TINT == 1
    return color * float3(1.0, 0.92, 0.85);
#elif NWB_SMOKE_MATERIAL_VERTEX_TINT == 0
    return color;
#else
#error "unsupported NWB_SMOKE_MATERIAL_VERTEX_TINT value"
#endif
}

float3 nwbSmokeMaterialVertexColor(float3 color){
    return clamp(nwbSmokeMaterialApplyVertexTint(nwbSmokeMaterialApplyColorTransform(color)), float3(0.0), float3(1.0));
}

float3 nwbSmokeMaterialPixelColor(float3 color){
    return color;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

