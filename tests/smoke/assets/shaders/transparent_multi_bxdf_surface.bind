[material_constant]
struct NwbTransparentMultiBxdfSurfaceMaterial{
    [default("float4(1.0, 1.0, 1.0, 1.0)")]
    float4 base_color;
};

[material_mutable]
struct NwbTransparentMultiBxdfRuntimeMaterial{
    [default("float4(1.0, 1.0, 1.0, 1.0)")]
    float4 color_tint;
};

NwbTransparentMultiBxdfSurfaceMaterial surface;
NwbTransparentMultiBxdfRuntimeMaterial runtime;


