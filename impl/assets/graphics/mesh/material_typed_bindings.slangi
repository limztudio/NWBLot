////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_MESH_MATERIAL_TYPED_BINDINGS_SLANGI
#define NWB_GRAPHICS_MESH_MATERIAL_TYPED_BINDINGS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "binding_slots.h"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// The per-instance data + the typed material-constant buffer, shared by the mesh stage (runtime.slangi) and
// the pixel stage (the material pixel shader, via gbuffer_io.slangi). Both bind the same set/slots; the
// material-bind generated accessors (nwbMaterialBind*) read these in whichever stage includes them.
struct NwbMeshInstanceData{
    float4 rotation;
    float3 translation;
    uint materialMutableByteOffset;
    float4 scale;
};

[[vk::binding(NWB_MESH_BINDING_MATERIAL_TYPED, NWB_MESH_SET)]] StructuredBuffer<uint, Std430DataLayout> g_NwbMaterialTypedWords;
[[vk::binding(NWB_MESH_BINDING_INSTANCE, NWB_MESH_SET)]] StructuredBuffer<NwbMeshInstanceData, Std430DataLayout> g_NwbMeshInstances;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
