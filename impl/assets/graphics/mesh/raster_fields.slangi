////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_MESH_RASTER_FIELDS_SLANGI
#define NWB_GRAPHICS_MESH_RASTER_FIELDS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#define NWB_MESH_RASTER_PAYLOAD_FIELDS \
    [[vk::location(0)]] float4 color : COLOR0; \
    [[vk::location(1)]] float3 normal : NORMAL0; \
    [[vk::location(2)]] float4 tangent : TANGENT0; \
    [[vk::location(3)]] float2 uv0 : TEXCOORD0; \
    [[vk::location(4)]] float3 worldPosition : TEXCOORD1;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbMeshRasterVertex{
    float4 position : SV_Position;
    NWB_MESH_RASTER_PAYLOAD_FIELDS
};

NwbMeshRasterVertex nwbMeshBuildRasterVertex(
    const float4 position,
    const float4 color,
    const float3 normal,
    const float4 tangent,
    const float2 uv0,
    const float3 worldPosition
){
    NwbMeshRasterVertex vertex;
    vertex.position = position;
    vertex.color = color;
    vertex.normal = normal;
    vertex.tangent = tangent;
    vertex.uv0 = uv0;
    vertex.worldPosition = worldPosition;
    return vertex;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

