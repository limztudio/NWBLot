////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#version 460


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


layout(set = 0, binding = 0) uniform texture2D g_UiTexture;
layout(set = 0, binding = 1) uniform sampler g_UiSampler;

layout(location = 0) in vec2 inUv;
layout(location = 1) in vec4 inColor;
layout(location = 0) out vec4 outColor;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


void main(){
    outColor = inColor * texture(sampler2D(g_UiTexture, g_UiSampler), inUv);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

