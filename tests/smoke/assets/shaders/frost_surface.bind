
[material_constant]
struct NwbFrostSurfaceMaterial{
    [default("half4(0.2, 0.4, 0.9, 1.0)")]
    half4 frost_albedo;
    [default("half(0.5)")]
    half roughness_value;
};

[material_mutable]
struct NwbFrostRuntimeMaterial{
    [default("half3(1.0, 1.0, 1.0)")]
    half3 sparkle_tint;
};

NwbFrostSurfaceMaterial frost;
NwbFrostRuntimeMaterial sparkle;


