////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


[[vk::binding(0, 0)]] Texture2D<float4> g_UiTexture;
[[vk::binding(1, 0)]] SamplerState g_UiSampler;

struct NwbImguiPixelInput{
    [[vk::location(0)]] float2 uv : TEXCOORD0;
    [[vk::location(1)]] float4 color : COLOR0;
};

struct NwbImguiPixelOutput{
    [[vk::location(0)]] float4 color : SV_Target0;
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbImguiPixelOutput main(NwbImguiPixelInput input){
    NwbImguiPixelOutput output;
    output.color = input.color * g_UiTexture.Sample(g_UiSampler, input.uv);
    return output;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

