#include "occlusion.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Minimal hit group for the occlusion ray type. The raygen traces with RAY_FLAG_SKIP_CLOSEST_HIT_SHADER,
// so this never executes; it exists so the pipeline + shader binding table have a valid hit group for the
// scene geometry. The default payload visibility (0 = occluded) already encodes "blocked" on any hit.
[shader("closesthit")]
void main(inout NwbShadowOcclusionPayload payload, in BuiltInTriangleIntersectionAttributes attributes){
    payload.visibility = 0.0;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

