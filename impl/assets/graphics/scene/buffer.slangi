////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_SCENE_BUFFER_SLANGI
#define NWB_GRAPHICS_SCENE_BUFFER_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "binding_slots.h"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_SCENE_SHADING_SET
#define NWB_SCENE_SHADING_SET NWB_SCENE_SHADING_DEFAULT_SET
#endif

#ifndef NWB_SCENE_SHADING_BINDING
#define NWB_SCENE_SHADING_BINDING NWB_SCENE_SHADING_DEFAULT_BINDING
#endif

#ifndef NWB_SCENE_LIGHT_LIST_SET
#define NWB_SCENE_LIGHT_LIST_SET NWB_SCENE_LIGHT_LIST_DEFAULT_SET
#endif

#ifndef NWB_SCENE_LIGHT_LIST_BINDING
#define NWB_SCENE_LIGHT_LIST_BINDING NWB_SCENE_LIGHT_LIST_DEFAULT_BINDING
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbSceneShadingBuffer{
    // xyz = camera world position, w = active light count.
    float4 g_NwbSceneCameraPosition;
};

[[vk::binding(NWB_SCENE_SHADING_BINDING, NWB_SCENE_SHADING_SET)]]
ConstantBuffer<NwbSceneShadingBuffer, Std140DataLayout> g_NwbSceneShadingBuffer;

#define g_NwbSceneCameraPosition g_NwbSceneShadingBuffer.g_NwbSceneCameraPosition

struct NwbSceneLight{
    // xyz = world position (point/spot), w = spot inner cone cosine.
    float4 position;
    // directional: toward-light; spot: emission axis. w = spot outer cone cosine.
    float4 direction;
    // xyz = color, w = intensity.
    float4 colorIntensity;
    // x = range, y = light type, z = shadow slot (negative = none), w reserved.
    float4 params;
};

[[vk::binding(NWB_SCENE_LIGHT_LIST_BINDING, NWB_SCENE_LIGHT_LIST_SET)]]
StructuredBuffer<NwbSceneLight, Std430DataLayout> g_NwbSceneLights;

uint nwbSceneLightCount(){
    return uint(max(g_NwbSceneCameraPosition.w, 0.0));
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

