////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_SCENE_BUFFER_SLANGI
#define NWB_GRAPHICS_SCENE_BUFFER_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_SCENE_SHADING_SET
#define NWB_SCENE_SHADING_SET 0
#endif

#ifndef NWB_SCENE_SHADING_BINDING
#define NWB_SCENE_SHADING_BINDING 4
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbSceneShadingBuffer{
    float4 g_NwbSceneDirectionalLightDirection;
    float4 g_NwbSceneDirectionalLightColorIntensity;
    float4 g_NwbSceneCameraPosition;
};

[[vk::binding(NWB_SCENE_SHADING_BINDING, NWB_SCENE_SHADING_SET)]]
ConstantBuffer<NwbSceneShadingBuffer, Std140DataLayout> g_NwbSceneShadingBuffer;

#define g_NwbSceneDirectionalLightDirection g_NwbSceneShadingBuffer.g_NwbSceneDirectionalLightDirection
#define g_NwbSceneDirectionalLightColorIntensity g_NwbSceneShadingBuffer.g_NwbSceneDirectionalLightColorIntensity
#define g_NwbSceneCameraPosition g_NwbSceneShadingBuffer.g_NwbSceneCameraPosition


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


