////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_CSG_PIXEL_RUNTIME_SLANGI
#define NWB_GRAPHICS_CSG_PIXEL_RUNTIME_SLANGI

#include "runtime.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float nwbCsgPixelWorldDistanceTolerance(const float3 worldPosition){
    const float3 worldPositionDx = ddx(worldPosition);
    const float3 worldPositionDy = ddy(worldPosition);
    return max(length(worldPositionDx), length(worldPositionDy)) * 0.5;
}

bool nwbCsgReceiverPixelDiscard(const uint receiverIndex, const float3 worldPosition){
    return nwbCsgReceiverPixelDiscardWithWorldTolerance(
        receiverIndex,
        worldPosition,
        nwbCsgPixelWorldDistanceTolerance(worldPosition)
    );
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

