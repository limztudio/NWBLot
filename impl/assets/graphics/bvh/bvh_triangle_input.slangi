////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////



#ifndef NWB_GRAPHICS_BVH_TRIANGLE_INPUT_SLANGI
#define NWB_GRAPHICS_BVH_TRIANGLE_INPUT_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Shared build-kernel triangle input. Morton generation and bottom-up fitting both consume the exact same sorted
// triangle stream, so keep the binding declarations and byte-address decoding together.


#include "binding_slots.h"
#include "bvh_common.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


[[vk::push_constant]]
ConstantBuffer<NwbBvhBuildPushConstants> g_NwbBvhBuildPushConstants;

[[vk::binding(NWB_BVH_BUILD_BINDING_POSITIONS, NWB_BVH_BUILD_SET)]]
ByteAddressBuffer g_NwbBvhPositions;

[[vk::binding(NWB_BVH_BUILD_BINDING_TRIANGLE_INDICES, NWB_BVH_BUILD_SET)]]
ByteAddressBuffer g_NwbBvhTriangleIndices;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


void nwbBvhLoadTrianglePositions(
    const uint triangle,
    out float3 outP0,
    out float3 outP1,
    out float3 outP2
){
    const uint indexBase = triangle * 3u;
    const uint i0 = g_NwbBvhTriangleIndices.Load(indexBase * 4u);
    const uint i1 = g_NwbBvhTriangleIndices.Load((indexBase + 1u) * 4u);
    const uint i2 = g_NwbBvhTriangleIndices.Load((indexBase + 2u) * 4u);
    outP0 = asfloat(g_NwbBvhPositions.Load3(i0 * 12u));
    outP1 = asfloat(g_NwbBvhPositions.Load3(i1 * 12u));
    outP2 = asfloat(g_NwbBvhPositions.Load3(i2 * 12u));
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
