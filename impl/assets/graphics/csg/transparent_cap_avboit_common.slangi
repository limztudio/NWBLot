#ifndef NWB_GRAPHICS_CSG_TRANSPARENT_CAP_AVBOIT_COMMON_SLANGI
#define NWB_GRAPHICS_CSG_TRANSPARENT_CAP_AVBOIT_COMMON_SLANGI

#include "../mesh/runtime_constants.h"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbCsgTransparentCapAvboitPixelInput{
    [[vk::location(NWB_MESH_RASTER_COLOR_LOCATION)]] float4 color : COLOR0;
    [[vk::location(NWB_MESH_RASTER_NORMAL_LOCATION)]] float3 normal : NORMAL0;
    [[vk::location(NWB_MESH_RASTER_TANGENT_LOCATION)]] float4 tangent : TANGENT0;
    [[vk::location(NWB_MESH_RASTER_UV0_LOCATION)]] float2 uv0 : TEXCOORD0;
    [[vk::location(NWB_MESH_RASTER_WORLD_POSITION_LOCATION)]] float4 worldPosition : TEXCOORD1;
};

bool nwbCsgTransparentCapPixelDiscard(NwbCsgTransparentCapAvboitPixelInput input){
    const uint receiverIndex = uint(input.worldPosition.w + 0.5);
    const uint cutterIndex = uint(input.tangent.w + 0.5);
    return nwbCsgReceiverPixelDiscardExcept(receiverIndex, input.worldPosition.xyz, cutterIndex);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

