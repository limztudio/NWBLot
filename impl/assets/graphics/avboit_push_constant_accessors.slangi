////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_AVBOIT_PUSH_CONSTANT_ACCESSORS_SLANGI
#define NWB_AVBOIT_PUSH_CONSTANT_ACCESSORS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_AVBOIT_PUSH_CONSTANTS
#error "NWB_AVBOIT_PUSH_CONSTANTS must name an AVBOIT push-constant block before including avboit_push_constant_accessors.slangi"
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


uint nwbAvboitFullWidth(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitFrame.x;
}

uint nwbAvboitFullHeight(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitFrame.y;
}

uint nwbAvboitLowWidth(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitFrame.z;
}

uint nwbAvboitLowHeight(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitFrame.w;
}

uint nwbAvboitVirtualSliceCount(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitVolume.x;
}

uint nwbAvboitPhysicalSliceCount(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitVolume.y;
}

uint nwbAvboitExtinctionWordCount(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitVolume.z;
}

uint nwbAvboitCoverageWordCount(){
    return NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitVolume.w;
}

float nwbAvboitExtinctionFixedScale(){
    return max(NWB_AVBOIT_PUSH_CONSTANTS.nwbAvboitParams.y, 1.0);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

