#ifndef NWB_GRAPHICS_SHADOW_SW_SHADOW_EDGE_RECORD_SLANGI
#define NWB_GRAPHICS_SHADOW_SW_SHADOW_EDGE_RECORD_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Stage-3 compacted-edge record packing, shared by the classify+append pass (which writes records) and the indirect
// trace pass (which reads them): word0 = (x<<16)|y (full-res pixel, 16 bits each), word1 = the light-loop index. PURE
// uint math -- declares NO bindings (the edge-list/counter buffers are declared by the passes that own them).


uint nwbSwShadowPackPixel(const uint2 pixel){
    return (pixel.x << 16) | (pixel.y & 0xFFFFu);
}

uint2 nwbSwShadowUnpackPixel(const uint word){
    return uint2(word >> 16, word & 0xFFFFu);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

