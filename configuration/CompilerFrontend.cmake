include_guard(GLOBAL)

macro(nwb_configure_compiler_frontend)
    set(NWB_COMPILER_ID "${CMAKE_CXX_COMPILER_ID}")
    set(NWB_COMPILER_FRONTEND "${CMAKE_CXX_COMPILER_FRONTEND_VARIANT}")
    if(NOT NWB_COMPILER_FRONTEND)
        if(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
            set(NWB_COMPILER_FRONTEND "MSVC")
        else()
            set(NWB_COMPILER_FRONTEND "GNU")
        endif()
    endif()

    set(NWB_COMPILER_IS_CLANG FALSE)
    if(CMAKE_CXX_COMPILER_ID MATCHES "Clang")
        set(NWB_COMPILER_IS_CLANG TRUE)
    endif()

    set(NWB_COMPILER_IS_MSVC FALSE)
    if(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
        set(NWB_COMPILER_IS_MSVC TRUE)
    endif()

    set(NWB_COMPILER_FRONTEND_MSVC FALSE)
    set(NWB_COMPILER_FRONTEND_GNU FALSE)
    if(NWB_COMPILER_FRONTEND STREQUAL "MSVC")
        set(NWB_COMPILER_FRONTEND_MSVC TRUE)
    elseif(NWB_COMPILER_FRONTEND STREQUAL "GNU")
        set(NWB_COMPILER_FRONTEND_GNU TRUE)
    endif()

    set(NWB_COMPILER_IS_CLANG_CL FALSE)
    if(NWB_COMPILER_IS_CLANG AND NWB_COMPILER_FRONTEND_MSVC)
        set(NWB_COMPILER_IS_CLANG_CL TRUE)
    endif()

    set(NWB_COMPILER_IS_CLANG_GNU FALSE)
    if(NWB_COMPILER_IS_CLANG AND NWB_COMPILER_FRONTEND_GNU)
        set(NWB_COMPILER_IS_CLANG_GNU TRUE)
    endif()

    if(NWB_COMPILER_IS_CLANG_CL)
        set(NWB_COMPILER_DESCRIPTION "clang-cl")
    elseif(NWB_COMPILER_IS_CLANG_GNU)
        set(NWB_COMPILER_DESCRIPTION "clang++")
    else()
        set(NWB_COMPILER_DESCRIPTION "${CMAKE_CXX_COMPILER_ID}")
    endif()
endmacro()
