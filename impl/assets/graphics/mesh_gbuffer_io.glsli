////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
#ifndef NWB_MESH_GBUFFER_IO_GLSLI
#define NWB_MESH_GBUFFER_IO_GLSLI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


layout(location = 0) in mediump vec4 inColor;
layout(location = 1) in mediump vec3 inNormal;
layout(location = 2) in vec4 inTangent;
layout(location = 3) in vec2 inUv0;
layout(location = 4) in vec3 inWorldPosition;
layout(location = 0) out vec4 outGBufferBaseColor;
layout(location = 1) out vec4 outGBufferNormal;
layout(location = 2) out vec4 outGBufferWorldPosition;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


vec3 nwbGBufferEncodeNormal(vec3 normal){
    const float lengthSquared = dot(normal, normal);
    const vec3 normalVector = lengthSquared > 0.000001
        ? normal * inversesqrt(lengthSquared)
        : vec3(0.0, 0.0, 1.0)
    ;
    return normalVector * 0.5 + 0.5;
}

void nwbWriteMeshGBuffer(vec3 baseColor, vec3 normal, vec3 worldPosition){
    outGBufferBaseColor = vec4(clamp(baseColor, vec3(0.0), vec3(1.0)), 1.0);
    outGBufferNormal = vec4(nwbGBufferEncodeNormal(normal), 1.0);
    outGBufferWorldPosition = vec4(worldPosition, 1.0);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

