[material_constant]
struct NwbSmokeSurfaceMaterial{
    [default("half4(1.0, 1.0, 1.0, 1.0)")]
    half4 base_color;
};

[material_mutable]
struct NwbSmokeRuntimeMaterial{
    [default("half4(1.0, 1.0, 1.0, 1.0)")]
    half4 color_tint;
};

NwbSmokeSurfaceMaterial surface;
NwbSmokeRuntimeMaterial runtime;


