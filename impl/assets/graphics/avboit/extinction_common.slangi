////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_AVBOIT_EXTINCTION_COMMON_SLANGI
#define NWB_AVBOIT_EXTINCTION_COMMON_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "constants.h"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


uint nwbAvboitPhysicalExtinctionWordCount(){
    const uint roundedSliceCount = nwbAvboitPhysicalSliceCount() + NWB_AVBOIT_EXTINCTION_SLICES_PER_WORD - 1u;
    return roundedSliceCount / NWB_AVBOIT_EXTINCTION_SLICES_PER_WORD;
}

uint nwbAvboitExtinctionWordIndex(uint2 lowPixel, uint physicalSlice){
    const uint physicalWord = physicalSlice / NWB_AVBOIT_EXTINCTION_SLICES_PER_WORD;
    return (physicalWord * nwbAvboitLowHeight() + lowPixel.y) * nwbAvboitLowWidth() + lowPixel.x;
}

uint nwbAvboitExtinctionByteShift(uint physicalSlice){
    return (physicalSlice & (NWB_AVBOIT_EXTINCTION_SLICES_PER_WORD - 1u)) * NWB_AVBOIT_EXTINCTION_BYTE_BITS;
}

float nwbAvboitUnpackExtinctionByte(uint packedWord, uint physicalSlice){
    const uint packedByte = (packedWord >> nwbAvboitExtinctionByteShift(physicalSlice)) & NWB_AVBOIT_EXTINCTION_BYTE_MASK;
    return float(packedByte) / nwbAvboitExtinctionFixedScale();
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

