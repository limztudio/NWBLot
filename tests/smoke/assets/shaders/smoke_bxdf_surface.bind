[material_constant]
struct NwbSmokeBxdfSurfaceMaterial{
    [default("float4(1.0, 1.0, 1.0, 1.0)")]
    float4 base_color;
};

[material_mutable]
struct NwbSmokeBxdfRuntimeMaterial{
    [default("float4(1.0, 1.0, 1.0, 1.0)")]
    float4 color_tint;
};

NwbSmokeBxdfSurfaceMaterial surface;
NwbSmokeBxdfRuntimeMaterial runtime;


