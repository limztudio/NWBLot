////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_CSG_CAP_PROXY_MS_MAIN_SLANGI
#define NWB_GRAPHICS_CSG_CAP_PROXY_MS_MAIN_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_MESH_SHADER_EMULATION_COMPUTE
#define NWB_MESH_SHADER_EMULATION_COMPUTE 0
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if NWB_MESH_SHADER_EMULATION_COMPUTE


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbCsgCapProxyGeneratedVertex{
    float4 position;
    float3 normal;
    float padding0;
    float4 tangent;
    float2 uv0;
    float2 padding1;
    float4 color;
    float4 worldPosition;
};

[[vk::binding(NWB_CSG_BINDING_CAP_PROXY_GENERATED_VERTEX, NWB_CSG_CAP_PROXY_SET)]]
RWStructuredBuffer<NwbCsgCapProxyGeneratedVertex, Std430DataLayout> g_NwbCsgCapProxyGeneratedVertices;

NwbCsgCapProxyGeneratedVertex nwbCsgCapProxyGeneratedVertex(const NwbMeshRasterVertex vertex){
    NwbCsgCapProxyGeneratedVertex generatedVertex;
    generatedVertex.position = vertex.position;
    generatedVertex.normal = vertex.normal;
    generatedVertex.padding0 = 0.0;
    generatedVertex.tangent = vertex.tangent;
    generatedVertex.uv0 = vertex.uv0;
    generatedVertex.padding1 = float2(0.0);
    generatedVertex.color = vertex.color;
    generatedVertex.worldPosition = vertex.worldPosition;
    return generatedVertex;
}

NwbCsgCapProxyGeneratedVertex nwbCsgCapProxyCulledGeneratedVertex(){
    NwbCsgCapProxyGeneratedVertex generatedVertex;
    generatedVertex.position = float4(0.0, 0.0, 0.0, 1.0);
    generatedVertex.normal = float3(0.0, 1.0, 0.0);
    generatedVertex.padding0 = 0.0;
    generatedVertex.tangent = float4(1.0, 0.0, 0.0, 0.0);
    generatedVertex.uv0 = float2(0.0);
    generatedVertex.padding1 = float2(0.0);
    generatedVertex.color = float4(0.0);
    generatedVertex.worldPosition = float4(0.0);
    return generatedVertex;
}

void nwbCsgCapProxyStoreEmulatedPrimitive(
    const uint proxyIndex,
    const uint localPrimitive,
    const NwbMeshRasterVertex vertex0,
    const NwbMeshRasterVertex vertex1,
    const NwbMeshRasterVertex vertex2
){
    const uint vertexBase = proxyIndex * NWB_CSG_CAP_PROXY_EMULATION_VERTEX_COUNT_PER_PROXY + localPrimitive * 3u;
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 0u] = nwbCsgCapProxyGeneratedVertex(vertex0);
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 1u] = nwbCsgCapProxyGeneratedVertex(vertex1);
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 2u] = nwbCsgCapProxyGeneratedVertex(vertex2);
}

void nwbCsgCapProxyStoreCulledEmulatedPrimitive(const uint proxyIndex, const uint localPrimitive){
    const uint vertexBase = proxyIndex * NWB_CSG_CAP_PROXY_EMULATION_VERTEX_COUNT_PER_PROXY + localPrimitive * 3u;
    const NwbCsgCapProxyGeneratedVertex vertex = nwbCsgCapProxyCulledGeneratedVertex();
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 0u] = vertex;
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 1u] = vertex;
    g_NwbCsgCapProxyGeneratedVertices[vertexBase + 2u] = vertex;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


[numthreads(NWB_CSG_CAP_PROXY_GROUP_SIZE, 1, 1)]
void main(uint3 groupThreadID : SV_GroupThreadID, uint3 groupID : SV_GroupID){
    const uint proxyIndex = groupID.x;
    if(proxyIndex >= g_NwbCsgCapProxyPushConstants.dispatch.x)
        return;

    const uint groupThreadIndex = groupThreadID.x;
    const NwbCsgCapProxyGpuData item = g_NwbCsgCapProxies[proxyIndex];
    const bool itemMatches = nwbCsgCapProxyItemMatchesPassAndShape(item, NWB_CSG_CAP_PROXY_SHADER_SHAPE_ID);
    const NwbCsgCutter cutter = g_NwbCsgCutters[item.receiverCutterShapePass.y];
    const NwbCsgCapProxyShapeContext shapeContext = nwbCsgCapProxyBuildShapeContext(item, cutter);
    const uint primitiveCount = nwbCsgCapProxyShapePrimitiveCount(shapeContext);

    for(uint localPrimitive = groupThreadIndex; localPrimitive < NWB_CSG_CAP_PROXY_MAX_TRIANGLES; localPrimitive += NWB_CSG_CAP_PROXY_GROUP_SIZE){
        if(!itemMatches || localPrimitive >= primitiveCount){
            nwbCsgCapProxyStoreCulledEmulatedPrimitive(proxyIndex, localPrimitive);
            continue;
        }

        uint3 indices;
        nwbCsgCapProxyShapePrimitive(shapeContext, localPrimitive, indices);
        nwbCsgCapProxyStoreEmulatedPrimitive(
            proxyIndex,
            localPrimitive,
            nwbCsgCapProxyShapeVertex(shapeContext, item, cutter, indices.x),
            nwbCsgCapProxyShapeVertex(shapeContext, item, cutter, indices.y),
            nwbCsgCapProxyShapeVertex(shapeContext, item, cutter, indices.z)
        );
    }
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#else


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


[shader("mesh")]
[numthreads(NWB_CSG_CAP_PROXY_GROUP_SIZE, 1, 1)]
[outputtopology("triangle")]
void main(
    uint3 groupThreadID : SV_GroupThreadID,
    uint3 groupID : SV_GroupID,
    OutputVertices<NwbMeshRasterVertex, NWB_CSG_CAP_PROXY_MAX_VERTICES> vertices,
    OutputIndices<uint3, NWB_CSG_CAP_PROXY_MAX_TRIANGLES> triangles
){
    const uint proxyIndex = groupID.x;
    if(proxyIndex >= g_NwbCsgCapProxyPushConstants.dispatch.x){
        SetMeshOutputCounts(0u, 0u);
        return;
    }

    const uint groupThreadIndex = groupThreadID.x;
    const NwbCsgCapProxyGpuData item = g_NwbCsgCapProxies[proxyIndex];
    if(!nwbCsgCapProxyItemMatchesPassAndShape(item, NWB_CSG_CAP_PROXY_SHADER_SHAPE_ID)){
        SetMeshOutputCounts(0u, 0u);
        return;
    }

    const NwbCsgCutter cutter = g_NwbCsgCutters[item.receiverCutterShapePass.y];
    const NwbCsgCapProxyShapeContext shapeContext = nwbCsgCapProxyBuildShapeContext(item, cutter);
    const uint vertexCount = nwbCsgCapProxyShapeVertexCount(shapeContext);
    const uint primitiveCount = nwbCsgCapProxyShapePrimitiveCount(shapeContext);

    SetMeshOutputCounts(vertexCount, primitiveCount);

    for(uint localVertex = groupThreadIndex; localVertex < vertexCount; localVertex += NWB_CSG_CAP_PROXY_GROUP_SIZE)
        vertices[localVertex] = nwbCsgCapProxyShapeVertex(shapeContext, item, cutter, localVertex);

    for(uint localPrimitive = groupThreadIndex; localPrimitive < primitiveCount; localPrimitive += NWB_CSG_CAP_PROXY_GROUP_SIZE)
        nwbCsgCapProxyShapePrimitive(shapeContext, localPrimitive, triangles[localPrimitive]);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


