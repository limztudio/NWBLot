////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_ASSETS_CSG_CAPSULE_CAP_PROXY_HELPERS_SLANGI
#define NWB_ASSETS_CSG_CAPSULE_CAP_PROXY_HELPERS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "../../graphics/csg/cap_proxy/round_common.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


uint nwbCsgCapProxyCapsuleRowCount(const uint segments){
    return NWB_CSG_CAP_PROXY_MAX_ROWS;
}

float nwbCsgCapProxyCapsuleRadiusSlack(const float radiusShape, const uint segments, const uint rows){
    const float segmentHalfAngle = NWB_CSG_CAP_PROXY_PI / max(float(segments), 3.0);
    const uint capSteps = rows >= 7u ? 3u : 2u;
    const float rowHalfAngle = 0.25 * NWB_CSG_CAP_PROXY_PI / max(float(capSteps), 1.0);
    return nwbCsgCapProxyRoundRadiusSlack(radiusShape, max(segmentHalfAngle, rowHalfAngle));
}

void nwbCsgCapProxyCapsuleRow(
    const uint row,
    const uint rows,
    const float radius,
    const float halfHeight,
    out float y,
    out float ringRadius
){
    const uint capSteps = rows >= 7u ? 3u : 2u;
    if(row <= capSteps){
        const float angle = 0.5 * NWB_CSG_CAP_PROXY_PI * float(row) / float(capSteps);
        float sinAngle;
        float cosAngle;
        sincos(angle, sinAngle, cosAngle);
        y = halfHeight + radius * cosAngle;
        ringRadius = radius * sinAngle;
        return;
    }

    const uint bottomBegin = capSteps + 1u;
    const uint bottomRow = row - bottomBegin;
    const float angle = 0.5 * NWB_CSG_CAP_PROXY_PI * float(bottomRow) / float(capSteps);
    float sinAngle;
    float cosAngle;
    sincos(angle, sinAngle, cosAngle);
    y = -halfHeight - radius * sinAngle;
    ringRadius = radius * cosAngle;
}

#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
