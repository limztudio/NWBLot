#ifndef NWB_GRAPHICS_CSG_SHAPE_DISPATCH_SLANGI
#define NWB_GRAPHICS_CSG_SHAPE_DISPATCH_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "engine/csg/generated/built_in.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if !defined(NWB_CSG_SHAPE_EVAL_CHAIN)
#define NWB_CSG_SHAPE_EVAL_CHAIN nwbTryEvalEmptyCsgShape
#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbCsgSample nwbEvalCsgShape(const uint shapeType, const float3 shapePosition, const NwbCsgCutter cutter){
    NwbCsgSample sample;
    if(NWB_CSG_SHAPE_EVAL_CHAIN(shapeType, shapePosition, cutter, sample))
        return sample;
    return nwbInvalidCsgShapeSample();
}

float nwbEvalCsgShapeDistance(const uint shapeType, const float3 shapePosition, const NwbCsgCutter cutter){
    return nwbEvalCsgShape(shapeType, shapePosition, cutter).distance;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#undef NWB_CSG_SHAPE_EVAL_CHAIN


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

