////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_GRAPHICS_MESH_GBUFFER_IO_SLANGI
#define NWB_GRAPHICS_MESH_GBUFFER_IO_SLANGI

#include "pixel_input.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbMeshGBufferOutput{
    [[vk::location(NWB_MESH_GBUFFER_BASE_COLOR_LOCATION)]] float4 baseColor : SV_Target0;
    [[vk::location(NWB_MESH_GBUFFER_NORMAL_LOCATION)]] float4 normal : SV_Target1;
    [[vk::location(NWB_MESH_GBUFFER_WORLD_POSITION_LOCATION)]] float4 worldPosition : SV_Target2;
};

static float4 outGBufferBaseColor;
static float4 outGBufferNormal;
static float4 outGBufferWorldPosition;

NwbMeshGBufferOutput nwbBuildMeshGBufferOutput(){
    NwbMeshGBufferOutput output;
    output.baseColor = outGBufferBaseColor;
    output.normal = outGBufferNormal;
    output.worldPosition = outGBufferWorldPosition;
    return output;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float3 nwbGBufferEncodeNormal(float3 normal){
    const float lengthSquared = dot(normal, normal);
    const float3 normalVector = lengthSquared > 0.000001
        ? normal * rsqrt(lengthSquared)
        : float3(0.0, 0.0, 1.0)
    ;
    return normalVector * 0.5 + 0.5;
}

void nwbWriteMeshGBuffer(float3 baseColor, float3 normal, float3 worldPosition){
    outGBufferBaseColor = float4(clamp(baseColor, float3(0.0), float3(1.0)), 1.0);
    outGBufferNormal = float4(nwbGBufferEncodeNormal(normal), 1.0);
    outGBufferWorldPosition = float4(worldPosition, 1.0);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

