////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Surface hook fragment. Defines this material's nwbMaterialSurface(); the cook wraps it with the engine
// pixel-shader authoring + this material's typed .bind to generate the G-buffer pixel shader. Modulates a
// procedural UV checker by the material's base color.
#include "material_color.slangi"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float3 nwbProjectUvDebug(const float2 uv0){
    const float2 wrappedUv = frac(uv0);
    const float2 checkerCell = floor(wrappedUv * 8.0);
    const float checker = fmod(checkerCell.x + checkerCell.y, 2.0);
    const float3 uvColor = float3(wrappedUv, 1.0 - wrappedUv.x);
    return lerp(uvColor * 0.55, uvColor, checker);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbMeshSurface nwbMaterialSurface(){
    const NwbMeshInstanceData instance = nwbMeshLoadInstance();
    const NwbSurfaceMaterial surface = nwbMaterialBindLoadSurface(instance);
    const NwbRuntimeMaterial runtime = nwbMaterialBindLoadRuntime(instance);
    const float3 baseColor = (surface.base_color * runtime.color_tint).rgb;
    return nwbMakeMeshSurface(nwbProjectUvDebug(inUv0) * nwbMaterialVertexColor(baseColor), inNormal);
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
