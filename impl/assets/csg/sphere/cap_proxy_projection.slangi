////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_CSG_SPHERE_CAP_PROXY_PROJECTION
#define NWB_CSG_SPHERE_CAP_PROXY_PROJECTION


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


float3 nwbCsgCapProxyEnlargeSphereShapePosition(
    const float3 shapePosition,
    const NwbCsgCutter cutter,
    const float radiusSlack
){
    if(radiusSlack <= 0.0)
        return shapePosition;

    const float radius = max(cutter.parameter0.x + radiusSlack, 0.0001);
    return nwbCsgSphereNormal(shapePosition) * radius;
}

float3 nwbCsgCapProxyShrinkSphereShapePosition(
    const float3 shapePosition,
    const NwbCsgCutter cutter
){
    const float radius = max(cutter.parameter0.x, 0.0);
    return nwbCsgSphereNormal(shapePosition) * radius;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if defined(NWB_CSG_ENABLE_CAP_PROXY_SHAPE_CHAIN)


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if defined(NWB_CSG_CAP_PROXY_ENLARGE_SHAPE_CHAIN)
#define NWB_CSG_PREV_ENLARGE NWB_CSG_CAP_PROXY_ENLARGE_SHAPE_CHAIN
#else
#define NWB_CSG_PREV_ENLARGE nwbTryEnlargeEmptyCsgCapProxyShape
#endif

bool nwbTryEnlargeCsgSphereCapProxyShape(
    const uint shapeType,
    const float3 shapePosition,
    const NwbCsgCutter cutter,
    const float radiusSlack,
    out float3 outShapePosition
){
    if(shapeType == NWB_CSG_CAP_PROXY_CHAIN_SHAPE_ID){
        outShapePosition = nwbCsgCapProxyEnlargeSphereShapePosition(shapePosition, cutter, radiusSlack);
        return true;
    }
    return NWB_CSG_PREV_ENLARGE(shapeType, shapePosition, cutter, radiusSlack, outShapePosition);
}

#undef NWB_CSG_CAP_PROXY_ENLARGE_SHAPE_CHAIN
#define NWB_CSG_CAP_PROXY_ENLARGE_SHAPE_CHAIN nwbTryEnlargeCsgSphereCapProxyShape
#undef NWB_CSG_PREV_ENLARGE


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#if defined(NWB_CSG_CAP_PROXY_SHRINK_SHAPE_CHAIN)
#define NWB_CSG_PREV_SHRINK NWB_CSG_CAP_PROXY_SHRINK_SHAPE_CHAIN
#else
#define NWB_CSG_PREV_SHRINK nwbTryShrinkEmptyCsgCapProxyShape
#endif

bool nwbTryShrinkCsgSphereCapProxyShape(
    const uint shapeType,
    const float3 shapePosition,
    const NwbCsgCutter cutter,
    out float3 outShapePosition
){
    if(shapeType == NWB_CSG_CAP_PROXY_CHAIN_SHAPE_ID){
        outShapePosition = nwbCsgCapProxyShrinkSphereShapePosition(shapePosition, cutter);
        return true;
    }
    return NWB_CSG_PREV_SHRINK(shapeType, shapePosition, cutter, outShapePosition);
}

#undef NWB_CSG_CAP_PROXY_SHRINK_SHAPE_CHAIN
#define NWB_CSG_CAP_PROXY_SHRINK_SHAPE_CHAIN nwbTryShrinkCsgSphereCapProxyShape
#undef NWB_CSG_PREV_SHRINK

#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
