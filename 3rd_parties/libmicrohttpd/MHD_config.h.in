#cmakedefine HAVE_NANOSLEEP 1

/* Define to 1 if `SOCK_NONBLOCK' is defined. */
#cmakedefine HAVE_SOCK_NONBLOCK 1

/* Define to 1 if listen() shutdown works correctly on closed sockets. */
#cmakedefine HAVE_LISTEN_SHUTDOWN 1

/* Define to 1 if compiler supports __attribute__((format)) for MHD_FUNC. */
#cmakedefine HAVE_MHD_FUNC_ 1

/* Define to 1 if you have the C11 `gmtime_s' function (C11 form). */
#cmakedefine HAVE_C11_GMTIME_S 1

/* *** Other useful stuff *** */

#cmakedefine _GNU_SOURCE 1

/* Define to 1 if you have the ANSI C header files. */
#cmakedefine STDC_HEADERS 1

