////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#ifndef NWB_BXDF_MESH_VERTEX_SLANGI
#define NWB_BXDF_MESH_VERTEX_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


NwbMeshGeneratedVertex nwbMeshBuildVertex(
    uint triangleIndex,
    uint corner,
    NwbMeshSourceVertex source,
    const NwbMeshInstanceData instance
){
    const NwbBxdfSurfaceMaterial surface = nwbMaterialBindLoadSurface(instance);
    const NwbBxdfRuntimeMaterial runtime = nwbMaterialBindLoadRuntime(instance);
    const float4 tintedColor = surface.base_color * runtime.color_tint;
    return nwbMeshBuildGeneratedVertex(
        source.clipPosition,
        nwbMeshTransformDirection(source.normal, instance),
        float4(nwbMeshTransformDirection(source.tangent.xyz, instance), source.tangent.w),
        source.uv0,
        float4(nwbBxdfVertexColor(tintedColor.rgb), tintedColor.a),
        source.worldPosition
    );
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

