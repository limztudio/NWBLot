#ifndef NWB_GRAPHICS_MESH_RASTER_FIELDS_SLANGI
#define NWB_GRAPHICS_MESH_RASTER_FIELDS_SLANGI


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#include "runtime_constants.h"


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// Mesh colors, normals, and tangents are already stored as 16-bit mesh attributes. Keep the non-positional
// raster payload at that precision to reduce varying bandwidth on mobile GPUs; the pixel/AVBOIT paths explicitly
// promote directions back to float before normalization, frame construction, or material evaluation. UVs, world
// positions, clip positions, and depth deliberately remain float for derivative, transform, and CSG precision.
#define NWB_MESH_RASTER_PAYLOAD_FIELDS \
    [[vk::location(NWB_MESH_RASTER_COLOR_LOCATION)]] half4 color : COLOR0; \
    [[vk::location(NWB_MESH_RASTER_NORMAL_LOCATION)]] half3 normal : NORMAL0; \
    [[vk::location(NWB_MESH_RASTER_TANGENT_LOCATION)]] half4 tangent : TANGENT0; \
    [[vk::location(NWB_MESH_RASTER_UV0_LOCATION)]] float2 uv0 : TEXCOORD0; \
    [[vk::location(NWB_MESH_RASTER_WORLD_POSITION_LOCATION)]] float4 worldPosition : TEXCOORD1;


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


struct NwbMeshRasterVertex{
    float4 position : SV_Position;
    NWB_MESH_RASTER_PAYLOAD_FIELDS
};

NwbMeshRasterVertex nwbMeshBuildRasterVertex(
    const float4 position,
    const half4 color,
    const float3 normal,
    const float4 tangent,
    const float2 uv0,
    const float4 worldPosition
){
    NwbMeshRasterVertex vertex;
    vertex.position = position;
    vertex.color = color;
    vertex.normal = half3(normal);
    vertex.tangent = half4(tangent);
    vertex.uv0 = uv0;
    vertex.worldPosition = worldPosition;
    return vertex;
}


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


#endif


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

